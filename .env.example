STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price IDs — Legacy (one-time deck purchase, kept for backwards compat)
STRIPE_PRICE_DECK=price_xxx

# Stripe Price IDs — 3-Tier Subscriptions (REQUIRED for production)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_FOUNDER_MONTHLY=price_xxx
STRIPE_PRICE_FOUNDER_ANNUAL=price_xxx

# Stripe Price IDs — Add-ons (optional)
STRIPE_PRICE_ADDON_PITCH_COACH=price_xxx
STRIPE_PRICE_ADDON_VIDEO_DECK=price_xxx
STRIPE_PRICE_ADDON_MONTHLY_BRANDING=price_xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=your-secret-key-change-in-production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key for server-side operations (webhooks, token management)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models (configurable — defaults used if not set)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=your-openai-key
WHISPER_MODEL=whisper-1
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# Image generation model IDs
# Slide graphics (branded, text-accurate): gemini-3-pro-image-preview (Nano Banana Pro, paid preview)
#   Fallback: gemini-2.5-flash-image (stable, cheaper at $0.039/img)
SLIDE_IMAGE_MODEL=gemini-3-pro-image-preview

# Hero/stock images (photorealistic, high-res): imagen-4.0-ultra-generate-001
#   Alternatives: imagen-4.0-generate-001 (standard), imagen-4.0-fast-generate-001 (fastest/cheapest)
IMAGEN_MODEL=imagen-4.0-ultra-generate-001

# Analysis API key (REQUIRED in all environments — no auth bypass)
ANALYSIS_API_KEY=your-analysis-api-key

# Sentry (optional — error tracking disabled if not set)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=pitchdeck-biz
