STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price IDs (REQUIRED for production — falls back to dynamic price_data in dev)
# Products: "AI Pitch Deck" ($99 one-time), "Branding Asset Subscription" ($49/month)
STRIPE_PRICE_DECK=price_xxx
STRIPE_PRICE_SUBSCRIPTION=price_xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=your-secret-key-change-in-production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key for server-side operations (webhooks, token management)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models (configurable — defaults used if not set)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=your-openai-key
WHISPER_MODEL=whisper-1
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# Image Generation Models
IMAGEN_MODEL=imagen-3.0-generate-002
SLIDE_IMAGE_MODEL=gemini-2.0-flash-exp

# Analysis API key (REQUIRED in all environments — no auth bypass)
ANALYSIS_API_KEY=your-analysis-api-key

# Sentry (optional — error tracking disabled if not set)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=pitchdeck-biz
